OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o
TAVILY_API_KEY=your_tavily_api_key_here(tvly-)

# Slack通知（Incoming Webhook）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Slackトリガー（Bolt App）
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# LINE push通知（LINE Messaging API Broadcast: https://developers.line.biz）
# 1. LINE Developersでチャンネル作成 → Messaging API
# 2. チャンネルアクセストークン（長期）を発行
# 3. Botと友達になっている全ユーザーにbroadcast送信（無料プラン対応）
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token

# メール送信（SMTP）
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
